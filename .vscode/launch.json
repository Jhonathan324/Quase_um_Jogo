{
    "version": "2.0.0",
    "configurations": [
        {
            "name": "Debug SDL3",
            "type": "cppdbg",
            "request": "launch",

            "program": "${fileDirname}\\bin\\debug\\main.exe",
            "cwd": "${fileDirname}",

            "stopAtEntry": false,
            "externalConsole": false,

            "MIMode": "gdb",
            "miDebuggerPath": "C:\\Program Files\\CodeBlocks\\MinGW\\bin\\gdb.exe",

            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],

            "preLaunchTask": "build SDL3"
        }
    ]
}