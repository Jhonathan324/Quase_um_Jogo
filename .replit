modules = ["python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Release"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Debug"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "WebAssembly"

[[workflows.workflow]]
name = "Release"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start_release.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Debug"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start_debug.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "WebAssembly"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start_wasm.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80
